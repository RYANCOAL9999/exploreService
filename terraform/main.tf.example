resource "kubernetes_secret" "explore_service_secret" {
    metadata {
        name      = "explore-service-secret"
        namespace = "default"
    }

    # work for non-TLS enabled services with LoadBalancer with gRPC HTTP/2.
    type = "Opaque"

    # only work for TLS enabled services with LoadBalancer with gRPC HTTP/2.
    # type = "kubernetes.io/tls"

    data = {
        DB_PASSWORD = var.db_password

        # 💡 enable it for gRPC HTTP/2 needs SSL/TLS
        # "tls.crt" = filebase64("${path.module}/certs/tls.crt") # File path to the TLS certificate file
        # "tls.key" = filebase64("${path.module}/certs/tls.key") # File path to the TLS private key file
    }

}

resource "kubernetes_deployment" "explore_service" {
    metadata {
        name      = "explore-service"
        namespace = "default"
        labels = {
            app = "exploreService"
        }
    }

    spec {
        replicas = 2 # 🚀 

        strategy {
            type = "RollingUpdate"
            rolling_update {
                max_surge       = "1"
                max_unavailable = "0"
            }
        }

        selector {
            match_labels = {
                app = "exploreService"
            }
        }

        template {
            metadata {
                labels = {
                    app = "exploreService"
                }
            }

            spec {
                container {
                    name              = "exploreService"
                    image             = "${var.aws_account_id}.dkr.ecr.${var.aws_region}://"
                    image_pull_policy = "IfNotPresent"

                    port {
                        container_port = 50051
                        name           = "grpc"
                    }

                    readiness_probe {
                        grpc {
                            port    = 50051
                            service = "exploreService"
                        }
                        initial_delay_seconds = 5
                        period_seconds        = 5
                        timeout_seconds       = 2
                        failure_threshold     = 3
                    }

                    liveness_probe {
                        grpc {
                            port    = 50051
                            service = "exploreService"
                        }
                        initial_delay_seconds = 10
                        period_seconds        = 10
                        timeout_seconds       = 2
                        failure_threshold     = 3
                    }

                    security_context {
                        run_as_non_root = true
                        run_as_user     = 10001
                    }

                    env {
                        name  = "PORT"
                        value = "50051"
                    }

                    env {
                        name = "DB_PASSWORD"
                        value_from {
                            secret_key_ref {
                                name = kubernetes_secret.explore_service_secret.metadata[0].name
                                key  = "DB_PASSWORD"
                            }
                        }
                    }

                    env {
                        name  = "DB"
                        value = "host=${var.aurora_endpoint} user=postgres password=$(DB_PASSWORD) dbname=explore_db port=5432 sslmode=disable TimeZone=UTC"
                    }

                    resources {
                        limits = {
                            cpu    = "500m"
                            memory = "512Mi"
                        }
                        requests = {
                            cpu    = "100m"
                            memory = "256Mi"
                        }
                    }
                }
            }
        }
    }
}

resource "kubernetes_service" "explore_service" {
    metadata {
        name      = "explore-service"
        namespace = "default"
    }

    spec {
        selector = {
            app = "exploreService"
        }

        port {
            protocol    = "TCP"
            port        = 50051
            target_port = 50051

            # NodePort (The Direct-to-Machine Way) method
            # node_port   = 30123 # Outside client connect to NodeIP
        }

        type = "ClusterIP" # 💡 Using ClusterIP for internal communication within the Kubernetes cluster

        # NodePort (The Direct-to-Machine Way) method
        # type = "NodePort" # 💡 Using NodePort for external access to the service through a specific port on each node
        # Ensures traffic hits pods on the landing node directly, reducing network jitter
        # external_traffic_policy = "Local" 
    }
}

